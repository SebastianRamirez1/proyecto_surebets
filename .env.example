THE_ODDS_API_KEY=          # https://the-odds-api.com  (500 req/mes gratis)
ODDSPAPI_KEY=              # https://oddspapi.io       (250 req/mes gratis)
TELEGRAM_BOT_TOKEN=        # @BotFather → /newbot
TELEGRAM_CHAT_ID=          # /getUpdates con tu token

# Proveedor: mock | oddspapi | the_odds_api | scraper
# scraper = OddsPortal (sin API key, usa httpx + BeautifulSoup)
ODDS_PROVIDER=mock

MIN_PROFIT_MARGIN=0.005    # 0.5% mínimo de ganancia para notificar
TOTAL_STAKE=1000           # capital base para calcular apuestas
SCAN_INTERVAL=300          # segundos entre ciclos del scan loop
SPORTS=soccer              # comma-separated: soccer,tennis,basketball,...
ALLOWED_BOOKMAKERS=        # comma-separated; vacío = todas las casas

# --- Gestión de créditos API (solo aplica con oddspapi / the_odds_api) ---
# Cuánto tiempo (seg) se guardan los datos en caché sin volver a llamar al API
# 43200 = 12h → ~240 req/mes con soccer + 3 fixtures  ← recomendado
# 86400 = 24h → ~120 req/mes                          ← más holgado
API_CACHE_TTL=43200
MAX_FIXTURES_PER_SPORT=3   # máx partidos a consultar por deporte por ciclo
